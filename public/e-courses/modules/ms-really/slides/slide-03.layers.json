      "width": 486.1406824146981,
      "height": 208.35931758530182,
      "align": "left",
      "verticalAlign": "top",
      "paragraphs": [
        {
          "align": "left",
          "lineSpacingPt": 25,
          "runs": [
            {
              "text": "Without a defined way of working, there is no clear reference point to identify what went wrong or how to fix it. The same mistakes surface again and again, draining time, money, and morale.",
              "lineSpacingPt": 25,
              "fontSizePt": 15.5,
              "color": "#E5E0DF",
              "fontFamily": "\"Roboto\", system-ui, sans-serif",
              "fontWeight": 400,
              "fontStyle": "normal"
            }
          ]
        }
      ]
