      "paragraphs": [
        {
          "align": "left",
          "lineSpacingPt": 25,
          "runs": [
            {
              "text": "You cannot improve what is not defined. Without a baseline, there is nothing to measure, nothing to refine, and no way to build on past successes.",
              "lineSpacingPt": 25,
              "fontSizePt": 15.5,
              "color": "#E5E0DF",
              "fontFamily": "\"Roboto\", system-ui, sans-serif",
              "fontWeight": 400,
