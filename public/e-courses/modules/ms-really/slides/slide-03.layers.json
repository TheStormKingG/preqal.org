      "align": "left",
      "verticalAlign": "top",
      "paragraphs": [
        {
          "align": "left",
          "lineSpacingPt": 25,
          "runs": [
            {
              "text": "When processes live in people's heads rather than in documented systems, performance drops the moment a key person is absent. Customers experience inconsistency — excellent service one day, poor service the next.",
              "lineSpacingPt": 25,
              "fontSizePt": 15.5,
              "color": "#E5E0DF",
              "fontFamily": "\"Roboto\", system-ui, sans-serif",
              "fontWeight": 400,
              "fontStyle": "normal"
            }
          ]
        }
      ]
    },
