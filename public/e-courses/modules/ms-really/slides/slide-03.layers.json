            {
              "text": "No Path to Improvement",
              "lineSpacingPt": 24,
              "fontSizePt": 19.5,
              "color": "#E5E0DF",
              "fontFamily": "\"Saira\", system-ui, sans-serif",
              "fontWeight": 400,
              "fontStyle": "normal"
